#!/usr/bin/env bash

# Fetch unresolved PR review threads as JSON.
# Paginates through all threads, emits only unresolved.
# Usage: gh-pr-threads <owner> <repo> <number>

set -euo pipefail

command -v gh >/dev/null || { echo "error: gh required" >&2; exit 1; }
command -v jq >/dev/null || { echo "error: jq required" >&2; exit 1; }

[[ $# -eq 3 ]] || {
  echo "usage: gh-pr-threads <owner> <repo> <number>" >&2
  exit 1
}

owner="$1" repo="$2" number="$3"
cursor="" all="[]"

while true; do
  after=""
  [[ -n "$cursor" ]] && after=", after: \"$cursor\""

  page=$(gh api graphql -f query="
    query(\$o: String!, \$r: String!, \$n: Int!) {
      repository(owner: \$o, name: \$r) {
        pullRequest(number: \$n) {
          reviewThreads(first: 100${after}) {
            pageInfo { hasNextPage endCursor }
            nodes {
              id
              isResolved
              comments(first: 10) {
                nodes {
                  author { login }
                  body
                  path
                  line
                  diffHunk
                }
              }
            }
          }
        }
      }
    }" -F o="$owner" -F r="$repo" -F n="$number") ||
    { echo "error: graphql query failed" >&2; exit 1; }

  batch=$(echo "$page" | jq '[
    .data.repository.pullRequest
      .reviewThreads.nodes[]
    | select(.isResolved == false)
    | { id,
        comments: [.comments.nodes[]
          | {author: .author.login, body, path, line}]
      }
  ]')

  all=$(jq -s '.[0] + .[1]' \
    <(echo "$all") <(echo "$batch"))

  has_next=$(echo "$page" | jq -r \
    '.data.repository.pullRequest
      .reviewThreads.pageInfo.hasNextPage')
  [[ "$has_next" == "true" ]] || break

  cursor=$(echo "$page" | jq -r \
    '.data.repository.pullRequest
      .reviewThreads.pageInfo.endCursor')
done

echo "$all"
