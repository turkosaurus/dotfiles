#!/usr/bin/env bash

# Reply to and resolve a PR review thread.
# Usage: gh-pr-thread-resolve <thread-id> <body>

set -euo pipefail

command -v gh >/dev/null || { echo "error: gh required" >&2; exit 1; }

[[ $# -eq 2 ]] || {
  echo "usage: gh-pr-thread-resolve <thread-id> <body>" >&2
  exit 1
}

gh api graphql -f query='
  mutation($id: ID!, $body: String!) {
    addPullRequestReviewThreadReply(
      input: {
        pullRequestReviewThreadId: $id
        body: $body
      }
    ) { comment { id } }
  }' -f id="$1" -f body="$2" > /dev/null ||
  { echo "error: reply failed for $1" >&2; exit 1; }

gh api graphql -f query='
  mutation($id: ID!) {
    resolveReviewThread(input: {threadId: $id}) {
      thread { isResolved }
    }
  }' -f id="$1" > /dev/null ||
  { echo "error: resolve failed for $1" >&2; exit 1; }
