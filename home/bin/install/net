#!/usr/bin/env bash

# apt-get update
if ! apt-get update; then
    echo "apt-get update failed"
    exit 1
fi

# net tools (python managed by mise)
if ! apt-get install -y curl iproute2 iw iputils-ping tcpdump wireguard; then
    echo "apt-get install curl iproute2 iw iputils-ping tcpdump wireguard failed"
    exit 1
fi

