#!/usr/bin/env bash

set -eo pipefail

pkgs_linux=(curl iproute2 iw iputils-ping tcpdump wireguard podman)
pkgs_darwin=(iproute2mac podman)

case "$(uname -s)" in
Linux)
	sudo apt-get update -qq
	sudo apt-get install -y "${pkgs_linux[@]}"
	;;
Darwin)
	if ! command -v brew &>/dev/null; then
		echo "error: homebrew required" >&2
		exit 1
	fi
	brew install "${pkgs_darwin[@]}"
	;;
*)
	echo "error: unsupported OS: $(uname -s)" >&2
	exit 1
	;;
esac
