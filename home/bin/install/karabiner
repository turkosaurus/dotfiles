#!/usr/bin/env bash

case "$(uname -s)" in
Darwin)
	if ! command -v brew &>/dev/null; then
		echo "error: homebrew required" >&2
		exit 1
	fi
	if ! brew install --cask karabiner-elements; then
		echo "error: failed to install karabiner-elements" >&2
		exit 1
	fi
	echo "note: grant accessibility permissions in System Settings > Privacy & Security"
	;;
*)
	echo "skipping karabiner: macOS only"
	;;
esac
