#!/usr/bin/env bash

# Reply to a PR review thread.
# Usage: gh-pr-thread-reply <thread-id> <body>

set -euo pipefail

command -v gh >/dev/null || { echo "error: gh required" >&2; exit 1; }

[[ $# -eq 2 ]] || {
  echo "usage: gh-pr-thread-reply <thread-id> <body>" >&2
  exit 1
}

gh api graphql -f query='
  mutation($id: ID!, $body: String!) {
    addPullRequestReviewThreadReply(
      input: {
        pullRequestReviewThreadId: $id
        body: $body
      }
    ) { comment { id } }
  }' -f id="$1" -f body="$2" > /dev/null ||
  { echo "error: reply failed for $1" >&2; exit 1; }
