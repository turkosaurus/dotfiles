#!/usr/bin/env bash

# Sync local plan.md with the current PR description.
# Pulls PR body, diffs against plan.md, prompts to push local version.
# Usage: gh-pr-description-sync [path/to/plan.md]

red='\033[0;31m'
green='\033[0;32m'
dim='\033[2m'
reset='\033[0m'

if [[ ! -t 0 ]]; then
  exit 0
fi

plan="${1:-plan.md}"

if [[ ! -f "$plan" ]]; then
  echo -e "${red}error${reset}: $plan not found" >&2
  exit 1
fi

# fetch PR number for current branch
gh_err=$(mktemp)
if ! pr=$(timeout 3 gh pr view --json number -q .number 2>"$gh_err"); then
  rc=$?
  msg=$(cat "$gh_err")
  rm -f "$gh_err"
  if [[ $rc -eq 124 ]]; then
    echo -e "${red}error${reset}: timed out reaching GitHub" >&2
    exit 1
  fi
  if [[ "$msg" == *"no pull requests"* ]]; then
    exit 0
  fi
  echo "$msg" >&2
  exit 1
fi
rm -f "$gh_err"

echo -e "${dim}PR #${pr}${reset}"

# fetch PR body
if ! remote=$(timeout 3 gh pr view --json body -q .body); then
  echo -e "${red}error${reset}: failed to fetch PR body" >&2
  exit 1
fi

local=$(cat "$plan")

if [[ "$remote" == "$local" ]]; then
  echo "already in sync"
  exit 0
fi

diff_out=$(diff --color=never <(echo "$remote") <(echo "$local")) || true
stat=$(awk '/^</{d++} /^>/{a++} END{printf "%d added, %d removed", a+0, d+0}' <<< "$diff_out")

printf "%s (%s) [y/d/N] " "$plan" "$stat"
if ! read -r -t 10 answer; then
  echo ""
  echo -e "${dim}timed out, skipping${reset}"
  exit 0
fi

if [[ "$answer" == [dD] ]]; then
  diff --color=always <(echo "$remote") <(echo "$local") | less -R || true
  printf "update PR description? [y/N] "
  if ! read -r -t 30 answer; then
    echo ""
    echo -e "${dim}timed out, skipping${reset}"
    exit 0
  fi
fi

if [[ "$answer" == [yY] ]]; then
  if ! timeout 3 gh pr edit "$pr" --body "$(cat "$plan")"; then
    echo -e "${red}error${reset}: failed to update PR" >&2
    exit 1
  fi
  echo -e "${green}updated${reset}"
else
  echo -e "${dim}skipped${reset}"
fi
