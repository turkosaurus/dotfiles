#!/usr/bin/env bash

# Sync local plan.md with the current PR description.
# Pulls PR body, diffs against plan.md, prompts to push local version.
# Usage: gh-pr-description-sync [path/to/plan.md]

set -euo pipefail

red='\033[0;31m'
green='\033[0;32m'
dim='\033[2m'
reset='\033[0m'

if [[ ! -t 0 ]]; then
  exit 0
fi

plan="${1:-plan.md}"

if [[ ! -f "$plan" ]]; then
  echo -e "${red}error${reset}: $plan not found" >&2
  exit 1
fi

# fetch PR number for current branch (3s timeout)
gh_err=$(mktemp)
pr=$(timeout 3 gh pr view --json number -q .number 2>"$gh_err")
rc=$?
if [[ $rc -eq 124 ]]; then
  rm -f "$gh_err"
  echo -e "${red}error${reset}: timed out reaching GitHub" >&2
  exit 1
elif [[ $rc -ne 0 ]]; then
  msg=$(cat "$gh_err")
  rm -f "$gh_err"
  echo "$msg" >&2
  if [[ "$msg" == *"no pull requests"* ]]; then
    exit 0
  fi
  exit 1
fi
rm -f "$gh_err"

echo -e "${dim}PR #${pr}${reset}"

# fetch PR body (3s timeout)
remote=$(timeout 3 gh pr view --json body -q .body)
rc=$?
if [[ $rc -eq 124 ]]; then
  echo -e "${red}error${reset}: timed out fetching PR body" >&2
  exit 1
elif [[ $rc -ne 0 ]]; then
  echo -e "${red}error${reset}: failed to fetch PR body" >&2
  exit 1
fi

local=$(cat "$plan")

if [[ "$remote" == "$local" ]]; then
  echo "already in sync"
  exit 0
fi

stat=$(diff --color=never <(echo "$remote") <(echo "$local") | \
  awk '/^</{d++} /^>/{a++} END{printf "%d added, %d removed", a+0, d+0}')

printf "%s (%s) [y/d/N] " "$plan" "$stat"
if ! read -r -t 10 answer; then
  echo ""
  echo -e "${dim}timed out, skipping${reset}"
  exit 0
fi

case "$answer" in
  [dD])
    diff --color=always <(echo "$remote") <(echo "$local") | less -R
    printf "update PR description? [y/N] "
    if ! read -r -t 30 answer2; then
      echo ""
      echo -e "${dim}timed out, skipping${reset}"
      exit 0
    fi
    if [[ "$answer2" != [yY] ]]; then
      echo -e "${dim}skipped${reset}"
      exit 0
    fi
    ;;&
  [yY])
    timeout 3 gh pr edit "$pr" --body "$(cat "$plan")"
    rc=$?
    if [[ $rc -eq 124 ]]; then
      echo -e "${red}error${reset}: timed out updating PR description" >&2
      exit 1
    elif [[ $rc -ne 0 ]]; then
      echo -e "${red}error${reset}: gh pr edit failed" >&2
      exit 1
    fi
    echo -e "${green}updated${reset}"
    ;;
  *)
    echo -e "${dim}skipped${reset}"
    ;;
esac
