#!/usr/bin/env bash

usage() {
	echo "git-commitas - commit as a specific identity"
	echo ""
	echo "usage: git commitas [-n name] [-e email] <commit args...>"
	echo ""
	echo "defaults to current git user if -n/-e not given"
}

AUTHOR_NAME=""
AUTHOR_EMAIL=""

while [ $# -gt 0 ]; do
	case "$1" in
		-n) AUTHOR_NAME="$2"; shift 2 ;;
		-e) AUTHOR_EMAIL="$2"; shift 2 ;;
		-h|--help) usage; exit 0 ;;
		*)  break ;;
	esac
done

if [ $# -eq 0 ]; then
	echo "error: commit args required"
	usage
	exit 1
fi

: "${AUTHOR_NAME:=$(git config user.name)}"
: "${AUTHOR_EMAIL:=$(git config user.email)}"

echo "committing as: $AUTHOR_NAME <$AUTHOR_EMAIL>"

GIT_AUTHOR_NAME="$AUTHOR_NAME" GIT_AUTHOR_EMAIL="$AUTHOR_EMAIL" \
	GIT_COMMITTER_NAME="$AUTHOR_NAME" GIT_COMMITTER_EMAIL="$AUTHOR_EMAIL" \
	git commit "$@"
