#!/usr/bin/env bash

# git-branches - list branches sorted by recent commits
# usage: git branches

# find default branch (main or master)
default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
if [[ -z "$default_branch" ]]; then
	if git show-ref --verify --quiet refs/heads/main; then
		default_branch="main"
	elif git show-ref --verify --quiet refs/heads/master; then
		default_branch="master"
	fi
fi

# collect branch data
branches=()
max_ref=0 max_upstream=0 max_vs=0 max_subject=0

while IFS='|' read -r head ref date upstream track subject; do
	# compute ahead/behind vs default branch
	if [[ -n "$default_branch" && "$ref" != "$default_branch" ]]; then
		ahead=$(git rev-list --count "$default_branch..$ref" 2>/dev/null || echo 0)
		behind=$(git rev-list --count "$ref..$default_branch" 2>/dev/null || echo 0)
		if [[ "$ahead" -gt 0 && "$behind" -gt 0 ]]; then
			vs_default="${default_branch} (+${ahead}/-${behind})"
			vs_status="mixed"
		elif [[ "$ahead" -gt 0 ]]; then
			vs_default="${default_branch} (+${ahead})"
			vs_status="ahead"
		elif [[ "$behind" -gt 0 ]]; then
			vs_default="${default_branch} (-${behind})"
			vs_status="behind"
		else
			vs_default="${default_branch} (0)"
			vs_status="even"
		fi
	else
		vs_default="-"
		vs_status="none"
	fi

	# combine upstream and track into one field
	if [[ -z "$upstream" ]]; then
		upstream_combined="-"
	elif [[ -z "$track" ]]; then
		upstream_combined="${upstream} (0)"
	else
		# transform [ahead N] → (+N), [behind N] → (-N), [ahead N, behind M] → (+N/-M)
		track_short=$(echo "$track" | sed -E 's/\[ahead ([0-9]+), behind ([0-9]+)\]/(+\1\/-\2)/; s/\[ahead ([0-9]+)\]/(+\1)/; s/\[behind ([0-9]+)\]/(-\1)/')
		upstream_combined="${upstream} ${track_short}"
	fi

	[[ -z "$head" ]] && head=" "

	# track max widths
	(( ${#ref} > max_ref )) && max_ref=${#ref}
	(( ${#upstream_combined} > max_upstream )) && max_upstream=${#upstream_combined}
	(( ${#vs_default} > max_vs )) && max_vs=${#vs_default}
	(( ${#subject} > max_subject )) && max_subject=${#subject}

	# store row
	branches+=("$head|$date|$ref|$upstream_combined|$vs_default|$vs_status|$subject")
done < <(git branch --sort=-committerdate \
	--format='%(HEAD)|%(refname:short)|%(committerdate:relative)|%(upstream:short)|%(upstream:track)|%(contents:subject)')

# color codes
if [[ -n "$NO_COLOR" ]]; then
	reset="" yellow="" green="" blue="" red="" dim="" grey=""
else
	reset=$'\033[0m' yellow=$'\033[33m' green=$'\033[32m'
	blue=$'\033[34m' red=$'\033[31m' dim=$'\033[2m' grey=$'\033[90m'
fi

# output with calculated widths
for row in "${branches[@]}"; do
	IFS='|' read -r head date ref upstream_combined vs_default vs_status subject <<< "$row"

	# pad values first (plain text)
	ref_pad=$(printf "%-${max_ref}s" "$ref")
	upstream_pad=$(printf "%-${max_upstream}s" "$upstream_combined")
	vs_pad=$(printf "%-${max_vs}s" "$vs_default")
	subject_pad=$(printf "%-${max_subject}s" "$subject")

	# then apply colors to padded strings
	ref_fmt="${blue}${ref_pad}${reset}"
	date_fmt="${dim}${date}${reset}"

	# upstream colors: green=ahead, red=behind, yellow=mixed, dim=even/none
	if [[ "$upstream_combined" == "-" ]]; then
		upstream_fmt="${dim}${upstream_pad}${reset}"
	elif [[ "$upstream_combined" == *"(0)"* ]]; then
		upstream_fmt="${dim}${upstream_pad}${reset}"
	elif [[ "$upstream_combined" == *"(+"*"/-"* ]]; then
		upstream_fmt="${yellow}${upstream_pad}${reset}"
	elif [[ "$upstream_combined" == *"(+"* ]]; then
		upstream_fmt="${green}${upstream_pad}${reset}"
	elif [[ "$upstream_combined" == *"(-"* ]]; then
		upstream_fmt="${red}${upstream_pad}${reset}"
	else
		upstream_fmt="${blue}${upstream_pad}${reset}"
	fi

	# vs_default colors: green=ahead, red=behind, yellow=mixed, dim=even/none
	case "$vs_status" in
		ahead) vs_fmt="${green}${vs_pad}${reset}" ;;
		behind) vs_fmt="${red}${vs_pad}${reset}" ;;
		mixed) vs_fmt="${yellow}${vs_pad}${reset}" ;;
		*) vs_fmt="${dim}${vs_pad}${reset}" ;;
	esac

	printf "%s  %s  %s  %s  %s  %s\n" \
		"$head" "$ref_fmt" "$upstream_fmt" "$vs_fmt" "$subject_pad" "$date_fmt"
done
