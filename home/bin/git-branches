#!/usr/bin/env bash

# git-branches - list branches sorted by recent commits
# usage: git branches

upstream='%(if)%(upstream)%(then)%(upstream:short)%(else)-%(end)'
track='%(if)%(upstream)%(then)%(if)%(upstream:track)%(then)%(upstream:track)%(else)(current)%(end)%(else)-%(end)'

if [[ -n "$NO_COLOR" ]]; then
	git branch --sort=-committerdate \
		--format="%(HEAD) %(committerdate:relative)%09%(refname:short)%09${upstream}%09${track}%09%(contents:subject)" |
		column -t -s $'\t'
else
	# track status: red when ahead/behind, dim when current
	track_color='%(if)%(upstream)%(then)%(if)%(upstream:track)%(then)%(color:red)%(upstream:track)%(color:reset)%(else)%(color:dim)(current)%(color:reset)%(end)%(else)%(color:dim)-%(color:reset)%(end)'
	git branch --sort=-committerdate \
		--format="%(HEAD) %(color:yellow)%(committerdate:relative)%(color:reset)%09%(color:green)%(refname:short)%(color:reset)%09%(color:blue)${upstream}%(color:reset)%09${track_color}%09%(contents:subject)" \
		--color=always |
		column -t -s $'\t'
fi
