#!/usr/bin/env bash

# work - manage git worktrees in ~/w with fuzzy finding
# usage: work [command] [args]
#
# commands:
#   work              create or switch
#   work <branch>     create worktree for branch (or switch if exists)
#   work .            move current branch to a new worktree
#   work main         switch to main worktree
#   work -            switch to previous worktree
#   work ls           list all worktrees
#   work rm [name]    remove a worktree (pick if no name)
#   work mv [old] <new>  rename a worktree (pick if no old)
#   work clean [-d]   remove worktrees with merged+clean branches
#
# worktrees are stored in ~/w/{repo}/{branch} with slashes as dashes
# e.g. "work a/feat" from ~/p/foo creates ~/w/foo/a-feat

set -euo pipefail

WORK_DIR="$HOME/w"
PREV_FILE="$WORK_DIR/.previous"
mkdir -p "$WORK_DIR"

error() {
  echo "error: $*" >&2
  exit 1
}

usage() {
  sed -n '3,17s/^# //p' "$0"
  exit "${1:-0}"
}

# save current dir as previous, then emit target path
goto() {
  pwd >"$PREV_FILE"
  echo "$1"
}

# human-readable time ago from epoch seconds
timeago() {
  local diff=$(( $(date +%s) - $1 ))
  if (( diff < 60 )); then echo "now"
  elif (( diff < 3600 )); then echo "$(( diff / 60 ))m"
  elif (( diff < 86400 )); then echo "$(( diff / 3600 ))h"
  elif (( diff < 604800 )); then echo "$(( diff / 86400 ))d"
  elif (( diff < 2592000 )); then echo "$(( diff / 604800 ))w"
  else echo "$(( diff / 2592000 ))mo"
  fi
}

# list worktree entries as "branch\trelpath\tage"
worktrees() {
  for dir in "$WORK_DIR"/*/*; do
    [[ -d "$dir" ]] || continue
    local rel="${dir#"$WORK_DIR"/}"
    local branch
    branch=$(git -C "$dir" symbolic-ref --short HEAD 2>/dev/null) ||
      branch="$rel"
    local mtime
    mtime=$(git -C "$dir" log -1 --format=%ct 2>/dev/null) ||
      mtime=$(stat -f %m "$dir" 2>/dev/null ||
              stat -c %Y "$dir" 2>/dev/null)
    printf '%s\t%s\t%s\n' "$branch" "$rel" "${mtime:-0}"
  done
}

# pick a worktree from numbered list, returns relpath
pick() {
  local entries
  entries=$(worktrees)
  [[ -z "$entries" ]] && error "no worktrees in $WORK_DIR"

  local maxw=0
  while IFS=$'\t' read -r branch rel _; do
    local name="${rel%%/*}:$branch"
    (( ${#name} > maxw )) && maxw=${#name}
  done <<<"$entries"
  (( maxw += 2 ))

  local i=1
  while IFS=$'\t' read -r branch rel mtime; do
    local r="${rel%%/*}"
    local ago
    ago=$(timeago "$mtime")
    printf "  %d) %-${maxw}s %6s\n" "$i" "$r:$branch" "($ago)" >&2
    ((i++))
  done <<<"$entries"

  local choice
  read -rp "select: " choice </dev/tty
  echo "$entries" | sed -n "${choice}p" | cut -f2
}

# remove a worktree directory, clean up empty repo dir
# prints main worktree path to stdout; returns 1 on failure
remove_worktree() {
  local dir="$1"
  local main_dir
  main_dir=$(git -C "$dir" worktree list | head -1 | awk '{print $1}')
  if ! git -C "$dir" worktree remove "$dir"; then
    return 1
  fi
  local repo_dir
  repo_dir=$(dirname "$dir")
  rmdir "$repo_dir" 2>/dev/null || true
  echo "$main_dir"
}

repo() {
  local root
  root=$(git rev-parse --show-toplevel 2>/dev/null) ||
    error "not in a git repo"
  basename "$root"
}

case "${1:-}" in
  -h | --help | help)
    usage
    ;;
  ls)
    entries=$(worktrees)
    maxw=0
    while IFS=$'\t' read -r branch rel _; do
      name="${rel%%/*}:$branch"
      (( ${#name} > maxw )) && maxw=${#name}
    done <<<"$entries"
    (( maxw += 2 ))
    while IFS=$'\t' read -r branch rel mtime; do
      dir="$WORK_DIR/$rel"
      pr_exit=0
      pr_info=$(cd "$dir" && timeout 3 gh pr view \
        --json number,state \
        --jq '[("#" + (.number|tostring)), (.state|ascii_downcase)] | @tsv' \
        2>/dev/null) || pr_exit=$?
      if [[ $pr_exit -eq 124 ]]; then
        pr_num="???" pr_state="???"
      else
        pr_num=$(printf '%s' "$pr_info" | cut -f1)
        pr_state=$(printf '%s' "$pr_info" | cut -f2)
      fi
      printf "%-${maxw}s  %-5s  %-6s  %s\n" \
        "${rel%%/*}:$branch" \
        "${pr_num:--}" \
        "${pr_state:--}" \
        "($(timeago "$mtime"))"
    done <<<"$entries"
    ;;
  rm)
    if [[ "${2:-}" == "." ]]; then
      [[ "$PWD" == "$WORK_DIR"/* ]] ||
        error "not inside a worktree"
      target="${PWD#"$WORK_DIR"/}"
    else
      target="${2:-$(pick)}"
    fi
    [[ -z "$target" ]] && error "no worktree selected"
    target_dir="$WORK_DIR/$target"
    main_dir=$(remove_worktree "$target_dir") ||
      error "could not remove $target"
    if [[ ! -d "${PWD}" ]]; then
      goto "$main_dir"
    fi
    ;;
  clean)
    dry=false
    case "${2:-}" in -d|--dry-run) dry=true ;; esac
    for dir in "$WORK_DIR"/*/*; do
      [[ -d "$dir" ]] || continue
      rel="${dir#"$WORK_DIR"/}"

      if ! branch=$(git -C "$dir" symbolic-ref --short HEAD 2>&1); then
        echo "skip $rel: not on a branch" >&2
        continue
      fi
      if [[ "$branch" == "main" || "$branch" == "master" ]]; then
        echo "skip $rel: is $branch" >&2
        continue
      fi

      pr_info=$(cd "$dir" && timeout 3 gh pr view \
        --json state,mergedAt \
        --jq '[.state, .mergedAt] | @tsv' 2>/dev/null) || pr_info=""
      pr_state=$(printf '%s' "$pr_info" | cut -f1)
      if [[ "$pr_state" != "MERGED" ]]; then
        echo "skip $rel: $branch not merged (${pr_state:-no pr})" >&2
        continue
      fi
      merged_at=$(printf '%s' "$pr_info" | cut -f2)
      merged_epoch=$(date -jf '%Y-%m-%dT%H:%M:%SZ' "$merged_at" +%s 2>/dev/null ||
        date -d "$merged_at" +%s 2>/dev/null)
      merged_ago=$(timeago "$merged_epoch")
      if ! git -C "$dir" diff --quiet 2>/dev/null ||
         ! git -C "$dir" diff --cached --quiet 2>/dev/null; then
        echo "skip $rel: dirty working tree" >&2
        continue
      fi

      if $dry; then
        echo "would rm $rel ($branch, merged $merged_ago ago)" >&2
        continue
      fi
      echo "rm   $rel ($branch, merged $merged_ago ago)" >&2
      if ! remove_worktree "$dir" >/dev/null; then
        echo "FAIL $rel: could not remove" >&2
        continue
      fi
    done
    ;;
  mv)
    old="${2:-$(pick)}"
    new="${3:-}"
    [[ -z "$old" ]] && error "no worktree selected"
    [[ -z "$new" ]] && error "new name required"
    old_dir="$WORK_DIR/$old"
    repo_dir=$(dirname "$old_dir")
    git -C "$old_dir" worktree move \
      "$old_dir" "$repo_dir/${new//\//-}"
    ;;
  -)
    [[ -f "$PREV_FILE" ]] || error "no previous worktree"
    prev=$(<"$PREV_FILE")
    [[ -d "$prev" ]] || error "previous dir no longer exists: $prev"
    goto "$prev"
    ;;
  "")
    target=$(pick)
    [[ -z "$target" ]] && error "no worktree selected"
    goto "$WORK_DIR/$target"
    ;;
  main)
    # try git directly; fall back to scanning WORK_DIR if cwd is gone
    dir=$(git worktree list 2>/dev/null | head -1 | awk '{print $1}')
    if [[ -z "$dir" ]]; then
      for d in "$WORK_DIR"/*/; do
        [[ -d "$d" ]] || continue
        dir=$(git -C "$d" worktree list 2>/dev/null |
          head -1 | awk '{print $1}')
        [[ -n "$dir" ]] && break
      done
    fi
    [[ -d "$dir" ]] || error "main worktree not found"
    goto "$dir"
    ;;
  .)
    branch=$(git symbolic-ref --short HEAD 2>/dev/null) ||
      error "not on a branch (detached HEAD)"
    [[ "$branch" == "main" || "$branch" == "master" ]] &&
      error "already on $branch, nothing to move"
    root=$(repo)
    dir="$WORK_DIR/${root}/${branch//\//-}"
    [[ -d "$dir" ]] && error "worktree already exists: $dir"
    mkdir -p "$WORK_DIR/$root"
    # switch main repo back to main, then create worktree
    git switch main >/dev/null 2>&1 ||
      git switch master >/dev/null 2>&1 ||
      error "could not switch back to main/master"
    git worktree add "$dir" "$branch" >&2 && goto "$dir"
    ;;
  *)
    slug="${1//\//-}"
    # check current repo first, then all repos
    root=$(repo)
    dir="$WORK_DIR/${root}/${slug}"
    if [[ ! -d "$dir" ]]; then
      for d in "$WORK_DIR"/*/"$slug"; do
        [[ -d "$d" ]] && dir="$d" && break
      done
    fi
    if [[ -d "$dir" ]]; then
      goto "$dir"
      exit
    fi
    mkdir -p "$WORK_DIR/$root"
    if git show-ref --verify --quiet \
      "refs/heads/$1" "refs/remotes/origin/$1" 2>/dev/null; then
      git worktree add "$dir" "$1" >&2
    else
      git worktree add -b "$1" "$dir" main >&2
    fi
    goto "$dir"
    ;;
esac
