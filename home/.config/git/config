[core]
	pager = less -FRX

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[rerere]
	enabled = true

[diff]
	algorithm = histogram

[merge]
	conflictstyle = zdiff3

[init]
	defaultBranch = main

[rebase]
	autoStash = true

[url "ssh://git@github.com/"]
	insteadOf = https://github.com/
