{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "OTEL_METRICS_EXPORTER": "otlp"
  },
  "permissions": {
    "allow": [
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(go run:*)",
      "Bash(go mod:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Read(~/.zshrc)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./*.env)",
      "Read(**/.git/config)",
      "Read(**/*secret*)",
      "Read(**/id_rsa*)",
      "Read(**/*.pem)"
    ]
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Computing"
    ]
  }
}

